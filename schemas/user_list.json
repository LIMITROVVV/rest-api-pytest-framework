{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserList",
  "type": "object",
  "required": ["page", "per_page", "total", "total_pages", "data"],
  "properties": {
    "page": { "type": "integer" },
    "per_page": { "type": "integer" },
    "total": { "type": "integer" },
    "total_pages": { "type": "integer" },
    "data": {
      "type": "array",
      "items": {
        "$ref": "user.json"
      }
    },
    "support": {
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "text": { "type": "string" }
      }
    }
  }
}
